# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only, NEVER expose to the browser).
# Used for writing sensitive config (e.g. the Drive OAuth refresh token)
# to the app_config table, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive album (for /photos uploads)
# Flow: an organizer signs in once at /admin/drive-auth. Google returns a
# refresh token which is stored in the app_config table and used for all
# subsequent uploads + gallery reads.
#
# 1. Create a GCP project and enable the Google Drive API.
# 2. Configure the OAuth consent screen (publish to Production, add the
#    `.../auth/drive` scope) — see /admin/drive-auth for details.
# 3. Create an OAuth Client ID (type: Web application). Add these
#    authorized redirect URIs, matching every env below you plan to use:
#      http://localhost:3000/auth/google/callback
#      https://<your-prod-domain>/auth/google/callback
# 4. Create a Drive folder that the *organizer* account owns, copy its ID
#    from the URL into GOOGLE_DRIVE_FOLDER_ID.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=

# --- Optional: Web Push (Phase 6 — browser notifications for inbox + live tracker) ---
# Not required until you implement Tasks 12–16 in
# docs/superpowers/plans/2026-04-23-admin-groups-push-implementation.md
# Generate keys: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# Optional: canonical site URL for push notification deep links (defaults to relative paths).
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Cab / transport request form is gated by super-admins in Admin Dashboard (app_config key
# cab_requests_beta_enabled). No env var required.
